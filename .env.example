ENV=dev
LOG_LEVEL=INFO

# Auth service
AUTH_HOST=0.0.0.0
AUTH_PORT=8001
AUTH_DB_URL=postgresql+asyncpg://bluecore:bluecore@postgres:5432/auth_db
JWT_SECRET=replace-with-secure-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_MINUTES=1440

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
AUTH_SERVICE_URL=http://auth:8001
RMS_SERVICE_URL=http://rms-service:8010
AI_REPORT_SERVICE_URL=http://ai-report-service:8020
AUDIT_SERVICE_URL=http://audit-service:8030
NOTIFICATION_SERVICE_URL=http://notification-service:8040
INTEGRATION_SERVICE_URL=http://integration-service:8050

# Alert engine
ALERT_ENGINE_HOST=0.0.0.0
ALERT_ENGINE_PORT=8060
ALERT_ENGINE_URL=http://alert-engine:8060
ALERT_DB_URL=postgresql+asyncpg://bluecore:bluecore@postgres:5432/alert_db
WEBSOCKET_GATEWAY_URL=http://websocket-gateway:8061
EVENT_STREAM_PREFIX=bluecore.alerts
KAFKA_INGRESS_TOPIC=bluecore.alerts.ingress
KAFKA_PROCESSED_TOPIC=bluecore.alerts.processed
ALERT_BRIDGE_ENABLED=true
ALERT_BRIDGE_SECRET=dev-bridge-secret-change-me
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Integration service
INTEGRATION_HOST=0.0.0.0
INTEGRATION_PORT=8050
INTEGRATION_DB_URL=sqlite+aiosqlite:///./integration.db
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-encryption-key!!
EVENT_STREAM_PREFIX=bluecore.integrations
WEBHOOK_BASE_URL=http://localhost:8050

# Eventing
EVENT_BUS_BACKEND=stdout
EVENT_BUS_TOPIC_PREFIX=bluecore
REDIS_URL=redis://redis:6379/0
EVENT_SIGNING_SECRET=replace-with-strong-signing-secret
OUTBOX_RELAY_POLL_SECONDS=5
OUTBOX_RELAY_MAX_RETRIES=5
EVENT_CONSUMER_GROUP=ops-analytics
EVENT_CONSUMER_NAME=consumer-1
OUTBOX_RELAY_METRICS_PORT=9110
OUTBOX_RELAY_CIRCUIT_OPEN_SECONDS=30
EVENT_CONSUMER_METRICS_PORT=9111
