  ASSIGNED
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  DISMISSED
}

enum ModerationEntityType {
  POST
  COMMENT
  USER
  LISTING
  REPORT
  MARKETPLACE
  OTHER
}

enum SuspensionStatus {
  ACTIVE
  EXPIRED
  LIFTED
}

enum AppealStatus {
  PENDING
  APPROVED
  DENIED
}

enum BroadcastSeverity {
