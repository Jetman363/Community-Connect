generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  RESIDENT
  BUSINESS_OWNER
  MODERATOR
  ADMIN
  PUBLIC_SAFETY
  HOA_MANAGER
}

enum CommunityMemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum PostCategory {
  GENERAL
  NEIGHBORHOOD
  SAFETY
  EVENTS
  MARKETPLACE
  HOA
}

enum AlertSeverity {
  INFO
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum AlertCategory {
  CRIME
  WEATHER
  TRAFFIC
  MISSING
  HOA
  COMMUNITY
  FIRE
  MEDICAL
  OTHER
}

enum ReportSeverity {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum IncidentCategory {
  HAZARD
  CRIME
  MAINTENANCE
  NOISE
  TRAFFIC
  ENVIRONMENTAL
  OTHER
}

enum ReportStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum GeofenceType {
  HOA
  EMERGENCY
  WATCH
}

enum MapLayerType {
  ALERTS
  REPORTS
  EVENTS
  BUSINESSES
  MARKETPLACE
  JOBS
  HEATMAP
}

enum WatchAreaType {
  HOME
  WORK
  CUSTOM
}

enum ListingType {
  FOR_SALE
  WANTED
  JOB
  SERVICE
}

enum MarketplaceCategory {
  BUY_SELL
  SERVICES
  JOBS
  GIG
  CLASSIFIEDS
  HOUSING
  OTHER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PENDING
  SOLD
  CLOSED
  EXPIRED
  FLAGGED
  REMOVED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  GIG
  VOLUNTEER
}

enum JobStatus {
  DRAFT
  ACTIVE
  FILLED
  CLOSED
  EXPIRED
  FLAGGED
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
  CLOSED
  SPAM
}

enum FavoriteTargetType {
  LISTING
  BUSINESS
  JOB
  SEARCH
}

enum VerificationType {
  IDENTITY
  LICENSE
  COMMUNITY
  PUBLIC_SAFETY
  HOA
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewModerationStatus {
  PENDING
  APPROVED
  FLAGGED
  REMOVED
}

enum PromotionTargetType {
  LISTING
  BUSINESS
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

enum MessageType {
  DIRECT
  COMMUNITY
  SYSTEM
}

enum NotificationType {
  INFO
  ALERT
  EVENT
  MESSAGE
  REPORT
  SYSTEM
  LIKE
  COMMENT
  REPLY
  MENTION
  FOLLOW
  MARKETPLACE
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  POLL
}

enum ReactionType {
  LIKE
  HELPFUL
  SUPPORT
  ALERT_ACK
}

enum FollowTargetType {
  USER
  BUSINESS
  COMMUNITY
  TOPIC
}

enum ContentReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ContentEntityType {
  POST
  COMMENT
  USER
  LISTING
}

enum MediaUploadStatus {
  PENDING
  UPLOADED
  FAILED
  DELETED
}

enum HoaDocumentCategory {
  BYLAWS
  MINUTES
  FINANCIAL
  NOTICE
  OTHER
}

enum VoteStatus {
  DRAFT
  OPEN
  CLOSED
}

// ─── Core ────────────────────────────────────────────────────────────────────

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  timezone    String   @default("America/New_York")
  logoUrl     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          CommunityMember[]
  posts            Post[]
  alerts           SafetyAlert[]
  events           Event[]
  businesses       Business[]
  listings         MarketplaceListing[]
  jobListings      JobListing[]
  reports          Report[]
  messages         Message[]
  hoaDocuments     HoaDocument[]
  hoaAnnouncements HOAAnnouncement[]
  votes            Vote[]
  mediaUploads     MediaUpload[]
  geofenceZones    GeofenceZone[]

  @@index([active])
}

model CommunityMember {
  id          String                @id @default(cuid())
  communityId String
  userId      String
  role        UserRole              @default(RESIDENT)
  status      CommunityMemberStatus @default(ACTIVE)
  joinedAt    DateTime              @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@index([communityId, status])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         UserRole @default(RESIDENT)
  verified     Boolean  @default(false)
  provider     String? // google | apple | facebook | local
  providerId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile              Profile?
  communityMemberships CommunityMember[]
  posts                Post[]
  comments             Comment[]
  reactions            Reaction[]
  reports              Report[]
  contentReports       ContentReport[]      @relation("ContentReporter")
  notifications        Notification[]
  savedPosts           SavedPost[]
  following            Follow[]             @relation("Follower")
  blockedUsers         UserBlock[]          @relation("Blocker")
  blockedBy            UserBlock[]          @relation("Blocked")
  mutedUsers           UserMute[]           @relation("Muter")
  mutedBy              UserMute[]           @relation("Muted")
  auditLogs            AuditLog[]           @relation("AuditActor")
  rsvps                RSVP[]
  marketplace          MarketplaceListing[]
  businesses           Business[]
  reviews              Review[]
  reviewHelpfulVotes   ReviewHelpfulVote[]
  reviewReports        ReviewReport[]
  inquiries            Inquiry[]
  favorites            Favorite[]
  jobListings          JobListing[]
  sentMessages         Message[]            @relation("SentMessages")
  receivedMessages     Message[]            @relation("ReceivedMessages")
  mediaUploads         MediaUpload[]
  createdAlerts        SafetyAlert[]        @relation("AlertCreator")
  assignedReports      Report[]             @relation("ReportAssignee")
  alertAcks            AlertAcknowledgment[]
  alertBookmarks       AlertBookmark[]
  alertSubscriptions   AlertSubscription[]
  watchAreas           WatchArea[]
  locationHistory      LocationHistory[]
  mapLayerPreference   MapLayerPreference?

  @@index([role])
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String
  avatarUrl    String?
  bio          String?
  neighborhood String?
  phone        String?
  badges       String[] @default([])
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Social ──────────────────────────────────────────────────────────────────

model Post {
  id          String       @id @default(cuid())
  communityId String
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String?
  content     String
  type        PostType     @default(TEXT)
  category    PostCategory @default(GENERAL)
  mediaUrls   String[]     @default([])
  videoUrl    String?
  hashtags    String[]     @default([])
  mentions    String[]     @default([])
  lat         Float?
  lng         Float?
  locationLabel String?
  pollData    Json?
  repostOfId  String?
  repostOf    Post?        @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts     Post[]       @relation("Reposts")
  shareCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  comments    Comment[]
  reactions   Reaction[]
  savedBy     SavedPost[]
  mediaUploads MediaUpload[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([communityId, category, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([category])
  @@index([repostOfId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  reactions Reaction[]

  @@index([postId, createdAt])
  @@index([parentId])
}

model Reaction {
  id        String       @id @default(cuid())
  postId    String?
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  @@unique([postId, userId, type])
  @@unique([commentId, userId, type])
  @@index([postId, type])
  @@index([commentId, type])
  @@index([userId])
}

model Follow {
  id          String           @id @default(cuid())
  followerId  String
  follower    User             @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  targetType  FollowTargetType
  targetId    String
  createdAt   DateTime         @default(now())

  @@unique([followerId, targetType, targetId])
  @@index([followerId])
  @@index([targetType, targetId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
}

model ContentReport {
  id          String              @id @default(cuid())
  reporterId  String
  reporter    User                @relation("ContentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  entityType  ContentEntityType
  entityId    String
  reason      String
  details     String?
  status      ContentReportStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([reporterId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model UserMute {
  id        String   @id @default(cuid())
  muterId   String
  muter     User     @relation("Muter", fields: [muterId], references: [id], onDelete: Cascade)
  mutedId   String
  muted     User     @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([muterId, mutedId])
  @@index([muterId])
}

// ─── Safety & Reports ────────────────────────────────────────────────────────

model SafetyAlert {
  id          String         @id @default(cuid())
  communityId String
  community   Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?          @relation("AlertCreator", fields: [createdById], references: [id], onDelete: SetNull)
  title       String
  description String
  category    AlertCategory  @default(OTHER)
  severity    AlertSeverity  @default(INFO)
  lat         Float?
  lng         Float?
  radiusM     Float? // meters — geofence broadcast radius
  locationLabel String?
  active      Boolean        @default(true)
  source      String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  expiresAt   DateTime?

  acknowledgments AlertAcknowledgment[]
  bookmarks       AlertBookmark[]

  @@index([communityId, active, createdAt(sort: Desc)])
  @@index([communityId, category, createdAt(sort: Desc)])
  @@index([severity])
  @@index([lat, lng])
  @@index([expiresAt])
}

model Report {
  id                String           @id @default(cuid())
  communityId       String
  community         Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reporterId        String
  reporter          User             @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  assignedToId      String?
  assignedTo        User?            @relation("ReportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  title             String
  description       String
  category          IncidentCategory @default(OTHER)
  severity          ReportSeverity   @default(MODERATE)
  suggestedCategory IncidentCategory?
  status            ReportStatus     @default(SUBMITTED)
  anonymous         Boolean          @default(false)
  lat               Float?
  lng               Float?
  locationLabel     String?
  mediaUrls         String[]         @default([])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([communityId, category])
  @@index([reporterId])
  @@index([assignedToId])
  @@index([lat, lng])
}

model GeofenceZone {
  id          String       @id @default(cuid())
  communityId String
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  name        String
  type        GeofenceType @default(WATCH)
  centerLat   Float?
  centerLng   Float?
  radiusM     Float?
  polygon     Json? // GeoJSON polygon coordinates
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subscriptions AlertSubscription[]

  @@index([communityId, active])
  @@index([centerLat, centerLng])
}

model AlertSubscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  zoneId          String?
  zone            GeofenceZone? @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  centerLat       Float?
  centerLng       Float?
  radiusM         Float?   @default(1609) // ~1 mile
  notifyEmergency Boolean  @default(true)
  notifyModerate  Boolean  @default(true)
  notifyInfo      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([userId, zoneId])
  @@index([userId])
  @@index([zoneId])
}

model AlertAcknowledgment {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertId   String
  alert     SafetyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, alertId])
  @@index([alertId])
}

model AlertBookmark {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertId   String
  alert     SafetyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, alertId])
  @@index([userId, createdAt(sort: Desc)])
}

model WatchArea {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      WatchAreaType @default(CUSTOM)
  centerLat Float
  centerLng Float
  radiusM   Float         @default(804) // ~0.5 mile
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model LocationHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Float?
  recordedAt DateTime @default(now())

  @@index([userId, recordedAt(sort: Desc)])
}

model MapLayerPreference {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  layers    MapLayerType[] @default([ALERTS, EVENTS, BUSINESSES])
  updatedAt DateTime       @updatedAt
}

// ─── Events ──────────────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String?
  location    String?
  lat         Float?
  lng         Float?
  startsAt    DateTime
  endsAt      DateTime?
  imageUrl    String?
  createdAt   DateTime @default(now())
  rsvps       RSVP[]

  @@index([communityId, startsAt])
}

model RSVP {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RsvpStatus @default(GOING)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
}

// ─── Business ────────────────────────────────────────────────────────────────

model Business {
  id                 String    @id @default(cuid())
  communityId        String
  community          Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  ownerId            String?
  owner              User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  name               String
  description        String?
  category           String
  categories         String[]  @default([])
  address            String?
  phone              String?
  website            String?
  lat                Float?
  lng                Float?
  rating             Float     @default(0)
  reviewCount        Int       @default(0)
  verified           Boolean   @default(false)
  verificationBadges String[]  @default([])
  imageUrl           String?
  logoUrl            String?
  coverPhotoUrl      String?
  hours              Json?
  socialLinks        Json?
  serviceAreas       String[]  @default([])
  pricingRange       String?
  certifications     String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  reviews               Review[]
  services              Service[]
  inquiries             Inquiry[]
  verificationRequests  VerificationRequest[]
  promotions            Promotion[]
  analytics             BusinessAnalytics?

  @@index([communityId, category])
  @@index([communityId, verified])
  @@index([ownerId])
  @@index([lat, lng])
}

model Review {
  id               String                 @id @default(cuid())
  businessId       String
  business         Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  authorId         String
  author           User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  rating           Int
  categoryRatings  Json?
  comment          String?
  photos           String[]               @default([])
  helpfulCount     Int                    @default(0)
  verifiedCustomer Boolean                @default(false)
  ownerResponse    String?
  ownerRespondedAt DateTime?
  moderationStatus ReviewModerationStatus @default(APPROVED)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  helpfulVotes ReviewHelpfulVote[]
  reports      ReviewReport[]

  @@unique([businessId, authorId])
  @@index([businessId, moderationStatus])
  @@index([authorId])
}

model ReviewHelpfulVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

model ReviewReport {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  details   String?
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  category        String
  priceFrom       Float?
  priceTo         Float?
  availability    String?
  serviceRadiusM  Float?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId, active])
}

// ─── Marketplace ─────────────────────────────────────────────────────────────

model MarketplaceListing {
  id           String              @id @default(cuid())
  communityId  String
  community    Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  sellerId     String
  seller       User                @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  price        Float?
  negotiable   Boolean             @default(false)
  type         ListingType         @default(FOR_SALE)
  category     MarketplaceCategory @default(BUY_SELL)
  status       ListingStatus       @default(ACTIVE)
  imageUrl     String?
  imageGallery Json?
  videoUrl     String?
  lat          Float?
  lng          Float?
  locationLabel String?
  featured     Boolean             @default(false)
  promoted     Boolean             @default(false)
  viewCount    Int                 @default(0)
  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  inquiries Inquiry[]
  promotions Promotion[]

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([communityId, category, status])
  @@index([communityId, featured, promoted])
  @@index([sellerId])
  @@index([lat, lng])
}

model JobListing {
  id          String     @id @default(cuid())
  communityId String
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  posterId    String
  poster      User       @relation(fields: [posterId], references: [id], onDelete: Cascade)
  businessId  String?
  title       String
  description String?
  jobType     JobType    @default(FULL_TIME)
  status      JobStatus  @default(ACTIVE)
  salaryMin   Float?
  salaryMax   Float?
  salaryUnit  String?
  skills      String[]   @default([])
  location    String?
  lat         Float?
  lng         Float?
  remote      Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expiresAt   DateTime?

  inquiries Inquiry[]

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([posterId])
  @@index([jobType])
}

model Inquiry {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  String?
  business    Business?     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  listingId   String?
  listing     MarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  jobId       String?
  job         JobListing?   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  message     String
  quoteRequest Boolean      @default(false)
  contactEmail String?
  contactPhone String?
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([businessId, status])
  @@index([listingId])
}

model Favorite {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType FavoriteTargetType
  targetId   String
  label      String?
  createdAt  DateTime           @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType])
}

model VerificationRequest {
  id         String             @id @default(cuid())
  businessId String
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       VerificationType
  status     VerificationStatus @default(PENDING)
  documents  String[]           @default([])
  adminNotes String?
  reviewedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([businessId])
}

model Promotion {
  id         String              @id @default(cuid())
  targetType PromotionTargetType
  listingId  String?
  listing    MarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  businessId String?
  business   Business?           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  startsAt   DateTime            @default(now())
  endsAt     DateTime?
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())

  @@index([active, endsAt])
  @@index([listingId])
  @@index([businessId])
}

model BusinessAnalytics {
  id            String   @id @default(cuid())
  businessId    String   @unique
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  viewCount     Int      @default(0)
  inquiryCount  Int      @default(0)
  listingViews  Int      @default(0)
  updatedAt     DateTime @updatedAt
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Message {
  id          String      @id @default(cuid())
  communityId String?
  community   Community?  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?       @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: SetNull)
  threadId    String?
  type        MessageType @default(DIRECT)
  content     String
  readAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  media MediaUpload[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([recipientId, readAt])
  @@index([threadId, createdAt])
  @@index([senderId])
}

// ─── HOA ─────────────────────────────────────────────────────────────────────

model HoaDocument {
  id          String              @id @default(cuid())
  communityId String
  community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  url         String
  category    HoaDocumentCategory @default(OTHER)
  createdAt   DateTime            @default(now())

  @@index([communityId, category])
}

model HOAAnnouncement {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  content     String
  priority    String    @default("normal")
  createdAt   DateTime  @default(now())

  @@index([communityId, createdAt(sort: Desc)])
}

model Vote {
  id          String     @id @default(cuid())
  communityId String
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String?
  options     String[]
  status      VoteStatus @default(DRAFT)
  endsAt      DateTime?
  createdAt   DateTime   @default(now())

  @@index([communityId, status])
}

// ─── Notifications & Media ───────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
}

model MediaUpload {
  id          String            @id @default(cuid())
  uploaderId  String
  uploader    User              @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  communityId String?
  community   Community?        @relation(fields: [communityId], references: [id], onDelete: SetNull)
  messageId   String?
  message     Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  postId      String?
  post        Post?             @relation(fields: [postId], references: [id], onDelete: SetNull)
  url         String
  mimeType    String
  sizeBytes   Int
  status      MediaUploadStatus @default(UPLOADED)
  entityType  String? // post | report | listing | profile
  entityId    String?
  createdAt   DateTime          @default(now())

  @@index([uploaderId])
  @@index([communityId])
  @@index([postId])
  @@index([entityType, entityId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  resource  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action, createdAt(sort: Desc)])
}
