# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/community_connect?schema=public"

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
SESSION_MAX_AGE_SECONDS="604800"

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_ENV="development"
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Redis (optional — in-memory fallback when unset) ────────────────────────
REDIS_URL=""

# ─── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_DSN=""
ENABLE_METRICS="false"

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER="console"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@communityconnect.app"
RESEND_API_KEY=""

# ─── AI (optional) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ─── Maps (optional) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ─── Realtime (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=""

# ─── File Storage ────────────────────────────────────────────────────────────
STORAGE_PROVIDER="local"
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED="true"

# ─── OAuth (stubs) ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# ─── Staging / Production overrides ──────────────────────────────────────────
# APP_ENV=staging|production
# NODE_ENV=production
# JWT_SECRET=<64+ char random>
# REDIS_URL=redis://...
# SENTRY_DSN=https://...
# EMAIL_PROVIDER=resend|smtp
# STORAGE_PROVIDER=s3
