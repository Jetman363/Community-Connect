  COMMUNITY
  SYSTEM
}

enum NotificationType {
  INFO
  ALERT
  EVENT
  MESSAGE
  REPORT
  SYSTEM
  LIKE
  COMMENT
  REPLY
  MENTION
  FOLLOW
  MARKETPLACE
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  POLL
}

enum ReactionType {
