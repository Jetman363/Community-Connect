generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  RESIDENT
  BUSINESS_OWNER
  MODERATOR
  ADMIN
  PUBLIC_SAFETY
  HOA_MANAGER
}

enum CommunityMemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum PostCategory {
  GENERAL
  NEIGHBORHOOD
  SAFETY
  EVENTS
  MARKETPLACE
  HOA
}

enum AlertSeverity {
  INFO
  ADVISORY
  WARNING
  EMERGENCY
}

enum ReportStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ListingType {
  FOR_SALE
  WANTED
  JOB
  SERVICE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  EXPIRED
  REMOVED
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

enum MessageType {
  DIRECT
  COMMUNITY
  SYSTEM
}

enum NotificationType {
  INFO
  ALERT
  EVENT
  MESSAGE
  REPORT
  SYSTEM
}

enum MediaUploadStatus {
  PENDING
  UPLOADED
  FAILED
  DELETED
}

enum HoaDocumentCategory {
  BYLAWS
  MINUTES
  FINANCIAL
  NOTICE
  OTHER
}

enum VoteStatus {
  DRAFT
  OPEN
  CLOSED
}

// ─── Core ────────────────────────────────────────────────────────────────────

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  timezone    String   @default("America/New_York")
  logoUrl     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          CommunityMember[]
  posts            Post[]
  alerts           SafetyAlert[]
  events           Event[]
  businesses       Business[]
  listings         MarketplaceListing[]
  reports          Report[]
  messages         Message[]
  hoaDocuments     HoaDocument[]
  hoaAnnouncements HOAAnnouncement[]
  votes            Vote[]
  mediaUploads     MediaUpload[]

  @@index([active])
}

model CommunityMember {
  id          String                @id @default(cuid())
  communityId String
  userId      String
  role        UserRole              @default(RESIDENT)
  status      CommunityMemberStatus @default(ACTIVE)
  joinedAt    DateTime              @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@index([communityId, status])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         UserRole @default(RESIDENT)
  verified     Boolean  @default(false)
  provider     String? // google | apple | facebook | local
  providerId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile              Profile?
  communityMemberships CommunityMember[]
  posts                Post[]
  comments             Comment[]
  likes                Like[]
  reports              Report[]
  notifications        Notification[]
  auditLogs            AuditLog[]           @relation("AuditActor")
  rsvps                RSVP[]
  marketplace          MarketplaceListing[]
  businesses           Business[]
  reviews              Review[]
  sentMessages         Message[]            @relation("SentMessages")
  receivedMessages     Message[]            @relation("ReceivedMessages")
  mediaUploads         MediaUpload[]

  @@index([role])
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String
  avatarUrl    String?
  bio          String?
  neighborhood String?
  phone        String?
  badges       String[] @default([])
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Social ──────────────────────────────────────────────────────────────────

model Post {
  id          String       @id @default(cuid())
  communityId String
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String?
  content     String
  category    PostCategory @default(GENERAL)
  mediaUrls   String[]     @default([])
  videoUrl    String?
  shareCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  comments Comment[]
  likes    Like[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([category])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// ─── Safety & Reports ────────────────────────────────────────────────────────

model SafetyAlert {
  id          String        @id @default(cuid())
  communityId String
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String
  severity    AlertSeverity @default(INFO)
  lat         Float?
  lng         Float?
  active      Boolean       @default(true)
  source      String? // police, fire, weather
  createdAt   DateTime      @default(now())
  expiresAt   DateTime?

  @@index([communityId, active, createdAt(sort: Desc)])
  @@index([severity])
}

model Report {
  id          String       @id @default(cuid())
  communityId String
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reporterId  String
  reporter    User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    String?
  aiCategory  String?
  status      ReportStatus @default(SUBMITTED)
  lat         Float?
  lng         Float?
  mediaUrls   String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([communityId, status])
  @@index([reporterId])
}

// ─── Events ──────────────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String?
  location    String?
  lat         Float?
  lng         Float?
  startsAt    DateTime
  endsAt      DateTime?
  imageUrl    String?
  createdAt   DateTime @default(now())
  rsvps       RSVP[]

  @@index([communityId, startsAt])
}

model RSVP {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RsvpStatus @default(GOING)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
}

// ─── Business ────────────────────────────────────────────────────────────────

model Business {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  ownerId     String?
  owner       User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  name        String
  description String?
  category    String
  address     String?
  phone       String?
  website     String?
  lat         Float?
  lng         Float?
  rating      Float     @default(0)
  verified    Boolean   @default(false)
  imageUrl    String?
  createdAt   DateTime  @default(now())
  reviews     Review[]

  @@index([communityId, category])
  @@index([ownerId])
}

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, authorId])
  @@index([businessId])
}

// ─── Marketplace ─────────────────────────────────────────────────────────────

model MarketplaceListing {
  id          String        @id @default(cuid())
  communityId String
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  price       Float?
  type        ListingType   @default(FOR_SALE)
  status      ListingStatus @default(ACTIVE)
  imageUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([sellerId])
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Message {
  id          String      @id @default(cuid())
  communityId String?
  community   Community?  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?       @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: SetNull)
  threadId    String?
  type        MessageType @default(DIRECT)
  content     String
  readAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  media MediaUpload[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([recipientId, readAt])
  @@index([threadId, createdAt])
  @@index([senderId])
}

// ─── HOA ─────────────────────────────────────────────────────────────────────

model HoaDocument {
  id          String              @id @default(cuid())
  communityId String
  community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  url         String
  category    HoaDocumentCategory @default(OTHER)
  createdAt   DateTime            @default(now())

  @@index([communityId, category])
}

model HOAAnnouncement {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  content     String
  priority    String    @default("normal")
  createdAt   DateTime  @default(now())

  @@index([communityId, createdAt(sort: Desc)])
}

model Vote {
  id          String     @id @default(cuid())
  communityId String
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String?
  options     String[]
  status      VoteStatus @default(DRAFT)
  endsAt      DateTime?
  createdAt   DateTime   @default(now())

  @@index([communityId, status])
}

// ─── Notifications & Media ───────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
}

model MediaUpload {
  id          String            @id @default(cuid())
  uploaderId  String
  uploader    User              @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  communityId String?
  community   Community?        @relation(fields: [communityId], references: [id], onDelete: SetNull)
  messageId   String?
  message     Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  url         String
  mimeType    String
  sizeBytes   Int
  status      MediaUploadStatus @default(UPLOADED)
  entityType  String? // post | report | listing | profile
  entityId    String?
  createdAt   DateTime          @default(now())

  @@index([uploaderId])
  @@index([communityId])
  @@index([entityType, entityId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  resource  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action, createdAt(sort: Desc)])
}
