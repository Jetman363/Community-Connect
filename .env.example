# Database (PostgreSQL — Railway, Supabase, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/community_connect?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI (optional — mock responses without key)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Google Maps (optional — placeholder UI without key)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Socket.io (optional — separate service in production)
NEXT_PUBLIC_SOCKET_URL=""

# Storage (local default; set s3 + AWS vars for cloud)
STORAGE_PROVIDER="local"
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# OAuth stubs (wire real providers in production)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
