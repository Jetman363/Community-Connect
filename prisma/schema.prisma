  CRIME
  WEATHER
  TRAFFIC
  MISSING
  HOA
  COMMUNITY
  FIRE
  MEDICAL
  OTHER
}

enum ReportSeverity {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum IncidentCategory {
  HAZARD
  CRIME
  MAINTENANCE
  NOISE
  TRAFFIC
  ENVIRONMENTAL
  OTHER
}

enum ReportStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum GeofenceType {
  HOA
  EMERGENCY
  WATCH
}

enum MapLayerType {
  ALERTS
  REPORTS
  EVENTS
  BUSINESSES
  MARKETPLACE
  JOBS
  HEATMAP
}

enum WatchAreaType {
  HOME
  WORK
  CUSTOM
}

enum ListingType {
  FOR_SALE
  WANTED
  JOB
  SERVICE
}

enum MarketplaceCategory {
  BUY_SELL
  SERVICES
  JOBS
  GIG
  CLASSIFIEDS
  HOUSING
  OTHER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PENDING
  SOLD
  CLOSED
  EXPIRED
  FLAGGED
  REMOVED
}

enum JobType {
  FULL_TIME
