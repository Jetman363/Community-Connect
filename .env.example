# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway, Supabase, Neon, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/community_connect?schema=public"

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret for signing JWT session tokens (use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-string-in-production"
# Token lifetime (e.g. 7d, 24h)
JWT_EXPIRES_IN="7d"

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV="development"
# Public URL used for links and OAuth callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AI (Phase 2 — optional) ─────────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ─── Maps (Phase 2 — optional) ───────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ─── Realtime (Phase 2 — optional) ───────────────────────────────────────────
# Socket.io server URL when running `npm run dev:socket`
NEXT_PUBLIC_SOCKET_URL=""

# ─── File Storage ────────────────────────────────────────────────────────────
# local | s3
STORAGE_PROVIDER="local"
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── OAuth (Phase 2+ — stubs only in Phase 1) ────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
