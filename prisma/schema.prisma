  MONTH
}

enum PointReason {
  CHECK_IN
  POST
  CHALLENGE
  DEAL_REDEMPTION
  ACHIEVEMENT
  REFERRAL
  OTHER
}

// ─── Core ────────────────────────────────────────────────────────────────────

model Community {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  timezone        String   @default("America/New_York")
  logoUrl         String?
  brandingColors  Json?
  settings        Json?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members              CommunityMember[]
  invites              CommunityInvite[]
  posts                Post[]
  alerts               SafetyAlert[]
  events               Event[]
  businesses           Business[]
  listings             MarketplaceListing[]
  jobListings          JobListing[]
  reports              Report[]
  messages             Message[]
  hoaDocuments         HoaDocument[]
  hoaAnnouncements     HOAAnnouncement[]
  votes                Vote[]
  communityRules       CommunityRule[]
  maintenanceRequests  MaintenanceRequest[]
  violationReports     ViolationReport[]
  meetings             Meeting[]
  mediaUploads         MediaUpload[]
  geofenceZones        GeofenceZone[]
  roleAssignments      UserRoleAssignment[]
  moderationCases      ModerationCase[]
  workflowCases        WorkflowCase[]
  tasks                Task[]
  broadcasts           Broadcast[]
  auditLogs            AuditLog[]
  dailyMetrics         DailyCommunityMetrics[]
  dailySafetyMetrics   DailySafetyMetrics[]
  integrationConnectors IntegrationConnector[]
  communityGroups      CommunityGroup[]
  localDeals           LocalDeal[]
  newsArticles         NewsArticle[]
  communityChallenges  CommunityChallenge[]
  trendingItems        TrendingItem[]

  @@index([active])
  @@index([organizationId])
}

model CommunityMember {
  id          String                @id @default(cuid())
  communityId String
  userId      String
  role        UserRole              @default(RESIDENT)
  status      CommunityMemberStatus @default(ACTIVE)
  joinedAt    DateTime              @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@index([communityId, status])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         UserRole @default(RESIDENT)
  verified     Boolean  @default(false)
  mfaEnabled   Boolean  @default(false)
  provider     String? // google | apple | facebook | local
  providerId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile              Profile?
  sessions             UserSession[]
  roleAssignments      UserRoleAssignment[]
  temporaryPermissions TemporaryPermission[]
  permissionAuditLogs  PermissionAuditLog[] @relation("PermissionAuditSubject")
  grantedPermissions   PermissionAuditLog[] @relation("PermissionAuditGranter")
  communityMemberships CommunityMember[]
  posts                Post[]
  comments             Comment[]
  reactions            Reaction[]
  reports              Report[]
  contentReports       ContentReport[]      @relation("ContentReporter")
  notifications        Notification[]
  savedPosts           SavedPost[]
  following            Follow[]             @relation("Follower")
  blockedUsers         UserBlock[]          @relation("Blocker")
  blockedBy            UserBlock[]          @relation("Blocked")
  mutedUsers           UserMute[]           @relation("Muter")
  mutedBy              UserMute[]           @relation("Muted")
  auditLogs            AuditLog[]           @relation("AuditActor")
  createdTasks         Task[]               @relation("TaskCreator")
  assignedTasks        Task[]               @relation("TaskAssignee")
  reportedModeration   ModerationCase[]     @relation("ModerationReporter")
  assignedModeration   ModerationCase[]     @relation("ModerationAssignee")
  suspensions          UserSuspension[]     @relation("SuspendedUser")
  issuedSuspensions    UserSuspension[]     @relation("SuspensionIssuer")
  appeals              Appeal[]
  communityInvites     CommunityInvite[]    @relation("InviteCreator")
  maintenanceRequests  MaintenanceRequest[]
  violationReports     ViolationReport[]
  voteBallots          VoteBallot[]
  rsvps                RSVP[]
  marketplace          MarketplaceListing[]
  businesses           Business[]
  reviews              Review[]
  reviewHelpfulVotes   ReviewHelpfulVote[]
  reviewReports        ReviewReport[]
  inquiries            Inquiry[]
  favorites            Favorite[]
  jobListings          JobListing[]
  sentMessages         Message[]            @relation("SentMessages")
  receivedMessages     Message[]            @relation("ReceivedMessages")
  mediaUploads         MediaUpload[]
  createdAlerts        SafetyAlert[]        @relation("AlertCreator")
  assignedReports      Report[]             @relation("ReportAssignee")
  alertAcks            AlertAcknowledgment[]
  alertBookmarks       AlertBookmark[]
  alertSubscriptions   AlertSubscription[]
  watchAreas           WatchArea[]
  locationHistory      LocationHistory[]
  mapLayerPreference   MapLayerPreference?
  groupMemberships     GroupMember[]
  savedDeals           SavedDeal[]
  dealRedemptions      DealRedemption[]
  communityPoints      CommunityPoints?
  pointTransactions    PointTransaction[]
  userAchievements     UserAchievement[]
  challengeParticipations ChallengeParticipation[]
  userInterests        UserInterest[]
  dailyCheckIns        DailyCheckIn[]
  personalizationProfile PersonalizationProfile?
  socialLinks            UserSocialLink[]

  @@index([role])
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String
  avatarUrl    String?
  bio          String?
  neighborhood String?
  phone        String?
  badges       String[] @default([])
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Social ──────────────────────────────────────────────────────────────────

model Post {
  id          String       @id @default(cuid())
  communityId String
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String?
  content     String
  type        PostType     @default(TEXT)
  category    PostCategory @default(GENERAL)
  mediaUrls   String[]     @default([])
  videoUrl    String?
  hashtags    String[]     @default([])
  mentions    String[]     @default([])
  lat         Float?
  lng         Float?
  locationLabel String?
  pollData    Json?
  repostOfId  String?
  repostOf    Post?        @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts     Post[]       @relation("Reposts")
  shareCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  comments    Comment[]
  reactions   Reaction[]
  savedBy     SavedPost[]
  mediaUploads MediaUpload[]
  groupPosts   GroupPost[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([communityId, category, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([category])
  @@index([repostOfId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  reactions Reaction[]

  @@index([postId, createdAt])
  @@index([parentId])
}

model Reaction {
  id        String       @id @default(cuid())
  postId    String?
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  @@unique([postId, userId, type])
  @@unique([commentId, userId, type])
  @@index([postId, type])
  @@index([commentId, type])
  @@index([userId])
}

model Follow {
  id          String           @id @default(cuid())
  followerId  String
  follower    User             @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  targetType  FollowTargetType
  targetId    String
  createdAt   DateTime         @default(now())

  @@unique([followerId, targetType, targetId])
  @@index([followerId])
  @@index([targetType, targetId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
}

model ContentReport {
  id          String              @id @default(cuid())
  reporterId  String
  reporter    User                @relation("ContentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  entityType  ContentEntityType
  entityId    String
  reason      String
  details     String?
  status      ContentReportStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([reporterId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model UserMute {
  id        String   @id @default(cuid())
  muterId   String
  muter     User     @relation("Muter", fields: [muterId], references: [id], onDelete: Cascade)
  mutedId   String
  muted     User     @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([muterId, mutedId])
  @@index([muterId])
}

// ─── Safety & Reports ────────────────────────────────────────────────────────

model SafetyAlert {
  id          String         @id @default(cuid())
  communityId String
  community   Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?          @relation("AlertCreator", fields: [createdById], references: [id], onDelete: SetNull)
  title       String
  description String
  category    AlertCategory  @default(OTHER)
  severity    AlertSeverity  @default(INFO)
  lat         Float?
  lng         Float?
  radiusM     Float? // meters — geofence broadcast radius
  locationLabel String?
  active      Boolean        @default(true)
  source      String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  expiresAt   DateTime?

  acknowledgments AlertAcknowledgment[]
  bookmarks       AlertBookmark[]

  @@index([communityId, active, createdAt(sort: Desc)])
  @@index([communityId, category, createdAt(sort: Desc)])
  @@index([severity])
  @@index([lat, lng])
  @@index([expiresAt])
}

model Report {
  id                String           @id @default(cuid())
  communityId       String
  community         Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reporterId        String
  reporter          User             @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  assignedToId      String?
  assignedTo        User?            @relation("ReportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  title             String
  description       String
  category          IncidentCategory @default(OTHER)
  severity          ReportSeverity   @default(MODERATE)
  suggestedCategory IncidentCategory?
  status            ReportStatus     @default(SUBMITTED)
  anonymous         Boolean          @default(false)
  lat               Float?
  lng               Float?
  locationLabel     String?
  mediaUrls         String[]         @default([])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([communityId, category])
  @@index([reporterId])
  @@index([assignedToId])
  @@index([lat, lng])
}

model GeofenceZone {
  id          String       @id @default(cuid())
  communityId String
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  name        String
  type        GeofenceType @default(WATCH)
  centerLat   Float?
  centerLng   Float?
  radiusM     Float?
  polygon     Json? // GeoJSON polygon coordinates
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subscriptions AlertSubscription[]

  @@index([communityId, active])
  @@index([centerLat, centerLng])
}

model AlertSubscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  zoneId          String?
  zone            GeofenceZone? @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  centerLat       Float?
  centerLng       Float?
  radiusM         Float?   @default(1609) // ~1 mile
  notifyEmergency Boolean  @default(true)
  notifyModerate  Boolean  @default(true)
  notifyInfo      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([userId, zoneId])
  @@index([userId])
  @@index([zoneId])
}

model AlertAcknowledgment {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertId   String
  alert     SafetyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, alertId])
  @@index([alertId])
}

model AlertBookmark {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertId   String
  alert     SafetyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, alertId])
  @@index([userId, createdAt(sort: Desc)])
}

model WatchArea {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      WatchAreaType @default(CUSTOM)
  centerLat Float
  centerLng Float
  radiusM   Float         @default(804) // ~0.5 mile
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model LocationHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Float?
  recordedAt DateTime @default(now())

  @@index([userId, recordedAt(sort: Desc)])
}

model MapLayerPreference {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  layers    MapLayerType[] @default([ALERTS, EVENTS, BUSINESSES])
  updatedAt DateTime       @updatedAt
}

// ─── Events ──────────────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String?
  location    String?
  lat         Float?
  lng         Float?
  startsAt    DateTime
  endsAt      DateTime?
  imageUrl    String?
  createdAt   DateTime @default(now())
  rsvps       RSVP[]

  @@index([communityId, startsAt])
}

model RSVP {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RsvpStatus @default(GOING)
  createdAt DateTime   @default(now())

  @@unique([eventId, userId])
}

// ─── Business ────────────────────────────────────────────────────────────────

model Business {
  id                 String    @id @default(cuid())
  communityId        String
  community          Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  ownerId            String?
  owner              User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  name               String
  description        String?
  category           String
  categories         String[]  @default([])
  address            String?
  phone              String?
  website            String?
  lat                Float?
  lng                Float?
  rating             Float     @default(0)
  reviewCount        Int       @default(0)
  verified           Boolean   @default(false)
  verificationBadges String[]  @default([])
  imageUrl           String?
  logoUrl            String?
  coverPhotoUrl      String?
  hours              Json?
  socialLinks        Json?
  serviceAreas       String[]  @default([])
  pricingRange       String?
  certifications     String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  reviews               Review[]
  services              Service[]
  inquiries             Inquiry[]
  verificationRequests  VerificationRequest[]
  promotions            Promotion[]
  analytics             BusinessAnalytics?
  localDeals            LocalDeal[]

  @@index([communityId, category])
  @@index([communityId, verified])
  @@index([ownerId])
  @@index([lat, lng])
}

model Review {
  id               String                 @id @default(cuid())
  businessId       String
  business         Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  authorId         String
  author           User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  rating           Int
  categoryRatings  Json?
  comment          String?
  photos           String[]               @default([])
  helpfulCount     Int                    @default(0)
  verifiedCustomer Boolean                @default(false)
  ownerResponse    String?
  ownerRespondedAt DateTime?
  moderationStatus ReviewModerationStatus @default(APPROVED)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  helpfulVotes ReviewHelpfulVote[]
  reports      ReviewReport[]

  @@unique([businessId, authorId])
  @@index([businessId, moderationStatus])
  @@index([authorId])
}

model ReviewHelpfulVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

model ReviewReport {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  details   String?
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  category        String
  priceFrom       Float?
  priceTo         Float?
  availability    String?
  serviceRadiusM  Float?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId, active])
}

// ─── Marketplace ─────────────────────────────────────────────────────────────

model MarketplaceListing {
  id           String              @id @default(cuid())
  communityId  String
  community    Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  sellerId     String
  seller       User                @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  price        Float?
  negotiable   Boolean             @default(false)
  type         ListingType         @default(FOR_SALE)
  category     MarketplaceCategory @default(BUY_SELL)
  status       ListingStatus       @default(ACTIVE)
  imageUrl     String?
  imageGallery Json?
  videoUrl     String?
  lat          Float?
  lng          Float?
  locationLabel String?
  featured     Boolean             @default(false)
  promoted     Boolean             @default(false)
  viewCount    Int                 @default(0)
  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  inquiries Inquiry[]
  promotions Promotion[]

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([communityId, category, status])
  @@index([communityId, featured, promoted])
  @@index([sellerId])
  @@index([lat, lng])
}

model JobListing {
  id          String     @id @default(cuid())
  communityId String
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  posterId    String
  poster      User       @relation(fields: [posterId], references: [id], onDelete: Cascade)
  businessId  String?
  title       String
  description String?
  jobType     JobType    @default(FULL_TIME)
  status      JobStatus  @default(ACTIVE)
  salaryMin   Float?
  salaryMax   Float?
  salaryUnit  String?
  skills      String[]   @default([])
  location    String?
  lat         Float?
  lng         Float?
  remote      Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expiresAt   DateTime?

  inquiries Inquiry[]

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([posterId])
  @@index([jobType])
}

model Inquiry {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  String?
  business    Business?     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  listingId   String?
  listing     MarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  jobId       String?
  job         JobListing?   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  message     String
  quoteRequest Boolean      @default(false)
  contactEmail String?
  contactPhone String?
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([businessId, status])
  @@index([listingId])
}

model Favorite {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType FavoriteTargetType
  targetId   String
  label      String?
  createdAt  DateTime           @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType])
}

model VerificationRequest {
  id         String             @id @default(cuid())
  businessId String
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       VerificationType
  status     VerificationStatus @default(PENDING)
  documents  String[]           @default([])
  adminNotes String?
  reviewedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([businessId])
}

model Promotion {
  id         String              @id @default(cuid())
  targetType PromotionTargetType
  listingId  String?
  listing    MarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  businessId String?
  business   Business?           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  startsAt   DateTime            @default(now())
  endsAt     DateTime?
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())

  @@index([active, endsAt])
  @@index([listingId])
  @@index([businessId])
}

model BusinessAnalytics {
  id            String   @id @default(cuid())
  businessId    String   @unique
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  viewCount     Int      @default(0)
  inquiryCount  Int      @default(0)
  listingViews  Int      @default(0)
  updatedAt     DateTime @updatedAt
}

// ─── Messaging ───────────────────────────────────────────────────────────────

model Message {
  id          String      @id @default(cuid())
  communityId String?
  community   Community?  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?       @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: SetNull)
  threadId    String?
  type        MessageType @default(DIRECT)
  content     String
  readAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  media MediaUpload[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([recipientId, readAt])
  @@index([threadId, createdAt])
  @@index([senderId])
}

// ─── HOA ─────────────────────────────────────────────────────────────────────

model HoaDocument {
  id          String              @id @default(cuid())
  communityId String
  community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  url         String
  category    HoaDocumentCategory @default(OTHER)
  createdAt   DateTime            @default(now())

  @@index([communityId, category])
}

model HOAAnnouncement {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  content     String
  priority    String    @default("normal")
  createdAt   DateTime  @default(now())

  @@index([communityId, createdAt(sort: Desc)])
}

model Vote {
  id              String     @id @default(cuid())
  communityId     String
  community       Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  options         String[]
  status          VoteStatus @default(DRAFT)
  anonymous       Boolean    @default(false)
  isBoardElection Boolean    @default(false)
  endsAt          DateTime?
  createdAt       DateTime   @default(now())

  ballots VoteBallot[]

  @@index([communityId, status])
}

model VoteBallot {
  id        String   @id @default(cuid())
  voteId    String
  vote      Vote     @relation(fields: [voteId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  optionIndex Int
  createdAt DateTime @default(now())

  @@index([voteId, userId])
}

// ─── Notifications & Media ───────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
}

model MediaUpload {
  id          String            @id @default(cuid())
  uploaderId  String
  uploader    User              @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  communityId String?
  community   Community?        @relation(fields: [communityId], references: [id], onDelete: SetNull)
  messageId   String?
  message     Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  postId      String?
  post        Post?             @relation(fields: [postId], references: [id], onDelete: SetNull)
  url         String
  mimeType    String
  sizeBytes   Int
  status      MediaUploadStatus @default(UPLOADED)
  entityType  String? // post | report | listing | profile
  entityId    String?
  createdAt   DateTime          @default(now())

  @@index([uploaderId])
  @@index([communityId])
  @@index([postId])
  @@index([entityType, entityId])
}

// ─── Phase 7: Enterprise & RBAC ─────────────────────────────────────────────

model Organization {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  type      OrganizationType @default(HOA)
  settings  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  communities           Community[]
  roleAssignments       UserRoleAssignment[]
  auditLogs             AuditLog[]
  integrationConnectors IntegrationConnector[]
  tenantBranding        TenantBranding?
  onboarding            OrganizationOnboarding?
  workflowAutomations   WorkflowAutomation[]

  @@index([type])
}

model Permission {
  id       String          @id @default(cuid())
  key      String          @unique
  resource String
  action   String
  scope    PermissionScope @default(COMMUNITY)
  label    String?

  rolePermissions      RolePermission[]
  temporaryPermissions TemporaryPermission[]
  auditLogs            PermissionAuditLog[]

  @@index([resource, action])
}

model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

model UserRoleAssignment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           UserRole
  communityId    String?
  community      Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  grantedById    String?
  createdAt      DateTime @default(now())

  @@unique([userId, role, communityId, organizationId])
  @@index([userId])
  @@index([communityId])
  @@index([organizationId])
}

model TemporaryPermission {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  communityId  String?
  grantedById  String?
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@index([userId, expiresAt])
}

model PermissionAuditLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("PermissionAuditSubject", fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  action       String
  grantedById  String?
  grantedBy    User?    @relation("PermissionAuditGranter", fields: [grantedById], references: [id], onDelete: SetNull)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model CommunityInvite {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  email       String
  token       String    @unique
  role        UserRole  @default(RESIDENT)
  invitedById String?
  invitedBy   User?     @relation("InviteCreator", fields: [invitedById], references: [id], onDelete: SetNull)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([communityId, email])
  @@index([token])
}

model CommunityRule {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  content     String
  category    String    @default("general")
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([communityId, active])
}

model MaintenanceRequest {
  id          String                   @id @default(cuid())
  communityId String
  community   Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User                     @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  title       String
  description String
  location    String?
  status      MaintenanceRequestStatus @default(SUBMITTED)
  priority    TaskPriority             @default(MEDIUM)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([communityId, status])
  @@index([requesterId])
}

model ViolationReport {
  id          String                @id @default(cuid())
  communityId String
  community   Community             @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reporterId  String
  reporter    User                  @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  address     String?
  description String
  status      ViolationReportStatus @default(SUBMITTED)
  anonymous   Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([communityId, status])
}

model Meeting {
  id          String        @id @default(cuid())
  communityId String
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  minutesUrl  String?
  status      MeetingStatus @default(SCHEDULED)
  createdAt   DateTime      @default(now())

  @@index([communityId, startsAt])
}

model Task {
  id          String       @id @default(cuid())
  communityId String?
  community   Community?   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  title       String
  notes       String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  entityType  String?
  entityId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([communityId, status])
  @@index([assigneeId, status])
  @@index([entityType, entityId])
}

model WorkflowCase {
  id          String             @id @default(cuid())
  communityId String
  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  type        WorkflowCaseType
  status      WorkflowCaseStatus @default(NEW)
  title       String
  description String?
  entityType  String?
  entityId    String?
  assigneeId  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([communityId, type, status])
}

model ModerationCase {
  id                  String               @id @default(cuid())
  communityId         String?
  community           Community?           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  entityType          ModerationEntityType
  entityId            String
  reporterId          String?
  reporter            User?                @relation("ModerationReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  aiConfidence        Float?
  status              ModerationCaseStatus @default(OPEN)
  assignedModeratorId String?
  assignedModerator   User?                @relation("ModerationAssignee", fields: [assignedModeratorId], references: [id], onDelete: SetNull)
  internalNotes       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([communityId, status])
  @@index([entityType, entityId])
}

model UserSuspension {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation("SuspendedUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedById  String?
  issuedBy    User?            @relation("SuspensionIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  reason      String
  status      SuspensionStatus @default(ACTIVE)
  expiresAt   DateTime?
  communityId String?
  createdAt   DateTime         @default(now())

  appeals Appeal[]

  @@index([userId, status])
}

model Appeal {
  id           String       @id @default(cuid())
  suspensionId String
  suspension   UserSuspension @relation(fields: [suspensionId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason       String
  status       AppealStatus @default(PENDING)
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@index([status, createdAt(sort: Desc)])
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  subject   String
  body      String
  channels  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  broadcasts Broadcast[]
}

model Broadcast {
  id          String            @id @default(cuid())
  communityId String
  community   Community         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  body        String
  severity    BroadcastSeverity @default(INFO)
  templateId  String?
  template    NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channels    Json?
  status      BroadcastStatus   @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdById String?
  createdAt   DateTime          @default(now())

  @@index([communityId, status])
}

model DailyCommunityMetrics {
  id          String   @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  counts      Json
  createdAt   DateTime @default(now())

  @@unique([communityId, date])
}

model DailySafetyMetrics {
  id          String   @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  counts      Json
  createdAt   DateTime @default(now())

  @@unique([communityId, date])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String?
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLogRetention {
  id              String   @id @default(cuid())
  organizationId  String?
  retentionDays   Int      @default(365)
  updatedAt       DateTime @updatedAt
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  actorId        String?
  actor          User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action         String
  resource       String?
  resourceId     String?
  metadata       Json?
  ip             String?
  communityId    String?
  community      Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([actorId])
  @@index([action, createdAt(sort: Desc)])
  @@index([communityId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([resource, resourceId])
}

// ─── Phase 9: Integrations & Enterprise ──────────────────────────────────────

model IntegrationConnector {
  id             String            @id @default(cuid())
  slug           String
  name           String
  category       ConnectorCategory
  enabled        Boolean           @default(false)
  config         Json?
  organizationId String?
  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  communityId    String?
  community      Community?        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  credentials   IntegrationCredential[]
  syncLogs      IntegrationSyncLog[]
  webhooks      IntegrationWebhook[]
  subscriptions IntegrationEventSubscription[]
  healthChecks  ConnectorHealthCheck[]

  @@unique([slug, organizationId, communityId])
  @@index([organizationId, enabled])
  @@index([communityId, enabled])
  @@index([category])
}

model IntegrationCredential {
  id               String         @id @default(cuid())
  connectorId      String
  connector        IntegrationConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  type             CredentialType @default(API_KEY)
  encryptedPayload String
  keyHint          String?
  rotatedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([connectorId])
}

model IntegrationSyncLog {
  id             String        @id @default(cuid())
  connectorId    String
  connector      IntegrationConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  direction      SyncDirection
  status         SyncStatus    @default(PENDING)
  payloadSummary String?
  error          String?
  createdAt      DateTime      @default(now())

  @@index([connectorId, createdAt(sort: Desc)])
  @@index([status])
}

model IntegrationWebhook {
  id          String   @id @default(cuid())
  connectorId String
  connector   IntegrationConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  url         String
  events      String[] @default([])
  secretHash  String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([connectorId, active])
}

model IntegrationEventSubscription {
  id          String   @id @default(cuid())
  connectorId String
  connector   IntegrationConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  eventType   String
  handler     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([connectorId, eventType])
  @@index([eventType, active])
}

model ConnectorHealthCheck {
  id          String                @id @default(cuid())
  connectorId String
  connector   IntegrationConnector  @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  status      ConnectorHealthStatus @default(UNKNOWN)
  lastCheck   DateTime              @default(now())
  metrics     Json?
  message     String?

  @@index([connectorId, lastCheck(sort: Desc)])
}

model WorkflowAutomation {
  id             String                @id @default(cuid())
  name           String
  trigger        AutomationTriggerType
  conditions     Json?
  actions        Json
  enabled        Boolean               @default(false)
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  communityId    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  runLogs AutomationRunLog[]

  @@index([organizationId, enabled])
  @@index([communityId])
}

model AutomationRunLog {
  id           String              @id @default(cuid())
  automationId String
  automation   WorkflowAutomation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status       AutomationRunStatus @default(PENDING)
  triggerData  Json?
  result       Json?
  error        String?
  createdAt    DateTime            @default(now())

  @@index([automationId, createdAt(sort: Desc)])
}

model TenantBranding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logoUrl        String?
  primaryColor   String?
  accentColor    String?
  domain         String?
  featureFlags   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model OnboardingStep {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model OrganizationOnboarding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  progress       Json
  completedAt    DateTime?
  updatedAt      DateTime     @updatedAt
}

// ─── Phase 10: Engagement & Lifestyle ────────────────────────────────────────

model CommunityGroup {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  name        String
  category    String
  description String?
  coverPhoto  String?
  memberCount Int       @default(0)
  isPrivate   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members GroupMember[]
  posts   GroupPost[]

  @@index([communityId, category])
  @@index([communityId, memberCount(sort: Desc)])
}

model GroupMember {
  id       String          @id @default(cuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId  String
  group    CommunityGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
}

model GroupPost {
  id        String         @id @default(cuid())
  groupId   String
  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?          @relation(fields: [postId], references: [id], onDelete: SetNull)
  content   String?
  createdAt DateTime       @default(now())

  @@index([groupId, createdAt(sort: Desc)])
  @@index([postId])
}

model LocalDeal {
  id            String    @id @default(cuid())
  communityId   String
  community     Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  discount      String
  dealType      DealType  @default(PERCENTAGE)
  expiresAt     DateTime
  redeemedCount Int       @default(0)
  imageUrl      String?
  createdAt     DateTime  @default(now())

  savedDeals  SavedDeal[]
  redemptions DealRedemption[]

  @@index([communityId, expiresAt])
  @@index([businessId])
}

model SavedDeal {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealId    String
  deal      LocalDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, dealId])
  @@index([userId, createdAt(sort: Desc)])
}

model DealRedemption {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealId     String
  deal       LocalDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  code       String?
  redeemedAt DateTime  @default(now())

  @@index([userId, redeemedAt(sort: Desc)])
  @@index([dealId])
}

model CommunityPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
}

model PointTransaction {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    PointReason
  createdAt DateTime    @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model Achievement {
  id          String  @id @default(cuid())
  key         String  @unique
  title       String
  description String
  icon        String?
  points      Int     @default(0)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

model CommunityChallenge {
  id               String    @id @default(cuid())
  communityId      String
  community        Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title            String
  description      String
  endDate          DateTime
  participantCount Int       @default(0)
  milestone        Int
  imageUrl         String?
  createdAt        DateTime  @default(now())

  participations ChallengeParticipation[]

  @@index([communityId, endDate])
}

model ChallengeParticipation {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   CommunityChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  progress    Int                @default(0)
  joinedAt    DateTime           @default(now())

  @@unique([userId, challengeId])
  @@index([challengeId])
}

model NewsArticle {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  source      String
  summary     String
  category    String
  publishedAt DateTime
  imageUrl    String?
  url         String?
  createdAt   DateTime  @default(now())

  @@index([communityId, publishedAt(sort: Desc)])
  @@index([communityId, category])
}

model UserInterest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic  String

  @@unique([userId, topic])
  @@index([userId])
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  streak    Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
}

model TrendingItem {
  id          String             @id @default(cuid())
  communityId String?
  community   Community?         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  entityType  TrendingEntityType
  entityId    String
  score       Float
  period      TrendingPeriod     @default(DAY)
  updatedAt   DateTime           @updatedAt

  @@unique([entityType, entityId, period, communityId])
  @@index([communityId, period, score(sort: Desc)])
}

model PersonalizationProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests   Json     @default("[]")
  preferences Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  TWITTER
  LINKEDIN
  YOUTUBE
}

model UserSocialLink {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   SocialPlatform
  profileUrl String
  username   String?
  connectedAt DateTime      @default(now())
  isPublic   Boolean        @default(true)
  updatedAt  DateTime       @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}
